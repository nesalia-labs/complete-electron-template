{
  "name": "complete-electron-template",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev -w apps/desktop",
    "build:web": "npm run build -w apps/web",
    "build:desktop": "npm run build -w apps/desktop",
    "setup": "tsx scripts/setup.ts",
    "clean": "tsx scripts/clean.ts",
    "reset:db": "tsx scripts/reset-db.ts",
    "outdated": "pnpm -r outdated",
    "outdated:summary": "tsx scripts/outdated.ts",
    "outdated:strict": "tsx scripts/outdated.ts --strict",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "ui:add": "cd packages/ui && npx shadcn@4.7.0 add",
    "postinstall": "node node_modules/electron/install.js && pnpm --filter \"./packages/*\" -r build"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^35.0.0",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "tw-animate-css": "^1.4.0"
  }
}