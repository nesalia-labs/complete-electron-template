{
  "name": "complete-electron-template",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:desktop": "npm run dev -w apps/desktop",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:desktop\"",
    "build:web": "npm run build -w apps/web",
    "build:desktop": "npm run build -w apps/desktop",
    "build:all": "npm run build -w apps/web && npm run build -w apps/desktop"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}