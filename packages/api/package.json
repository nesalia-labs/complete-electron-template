{
  "name": "@electron-template/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "import": "./dist/settings/index.js",
      "require": "./dist/settings/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@electron-template/db": "workspace:*",
    "@orpc/server": "^1.14.3",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@orpc/client": "^1.14.3",
    "vitest": "^4.0.0"
  }
}